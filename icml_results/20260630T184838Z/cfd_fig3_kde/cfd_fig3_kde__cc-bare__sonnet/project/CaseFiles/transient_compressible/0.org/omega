FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 5;


boundaryField
{
    walls
    {
        type            omegaWallFunction;
        blending        binomial2;
        value           $internalField;
    }

    hole    
    {
        type            zeroGradient;
    }

    "crac.*_inlet"
    {
        type            turbulentMixingLengthFrequencyInlet;
        mixingLength    0.1;
 	    k 			    k;
        value           $internalField;
    }
    "crac.*_outlet"
    {
        type            inletOutlet;
        value           $internalField;
        inletValue      uniform 5;
    }

    "rack.*_inlet"
    {
        type            turbulentMixingLengthFrequencyInlet;
        mixingLength    0.1;
 	    k 			    k;
        value           $internalField;
    }
    "rack.*_outlet"
    {
        type            inletOutlet;
        value           $internalField;
        inletValue      uniform 5;
    }

}



