FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    cellDisplacement
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-7;
        relTol          0.001;
    }

    p_rgh
    {
        solver PPCG;
        preconditioner DIC;
        tolerance 1e-6;
        relTol 0.001;
        minIter 3;
        maxIter 1000;
    }
/*
    p_rgh
    {
        solver           GAMG;
        smoother         DIC;
        tolerance        1e-6;
        relTol           0.001;
        minIter          1;
        maxIter          200;

        agglomerator     algebraicPair;

//        nCellsInCoarsestLevel 10; // needs to be low for directSolveCoarsest
//        directSolveCoarsest true;
//        coarsestLevelCorr
//        {
//            solver          PCGR;
//            preconditioner  DIC;
//            relTol          0.05;
//        }
    }
*/
    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }


    "(T|U|k|epsilon|R|omega)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-08; // refine after some time to 1e-8
        relTol          0.001;
    }
    "(U|T|k|epsilon|R|omega)Final"
    {
        $U;
        relTol          0;
    }

}


PIMPLE
{
    momentumPredictor yes;
    nOuterCorrectors 50;         
    nCorrectors     2;          
    nNonOrthogonalCorrectors 1;
    turbOnFinalIterOnly false;

//    pRefCell        0;
//    pRefValue       0;

    consistent      yes;    // PIMPLE_C

    residualControl
    {
        "(U|T|h|e|k|epsilon|omega|R)"
        {
                tolerance  1e-4;
                relTol      0;
        }
        p_rgh
        {
                tolerance  1e-5;
                relTol      0;
        }
    }

}


relaxationFactors
{
    fields
    {
        p_rgh           1;
        p_rghFinal      1;

    }
    equations
    {
        U                                 1;
        "(T|h|e)"                           1;
        "(k|epsilon|omega|R)"             1;
        "(U|T|h|k|epsilon|omega|R)Final"  1;

    }
}


