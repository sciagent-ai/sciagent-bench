FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      epsilon;        // EPSILON = Turbulent Dissipation Rate recalculate
                                // for each new case.   e=Cu*((k^(3/2))/l)   
                                // Cu=Turbulent Constant=0.09
                                // k=Turbulent Kinetic Energy     l=Turbulent Length Scale
                                // l can be estimated.  l=0.038*dh   dh=pipe diameter
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.001;

boundaryField
{

    walls
    {
        type            epsilonWallFunction;
        lowReCorrection on;
        value           $internalField; // placeholder
    }

    hole
    {
        type            zeroGradient;
    }

    "crac.*_inlet"
    {
        type            turbulentMixingLengthDissipationRateInlet;
        mixingLength    0.1;
        value           $internalField;
    }
    "crac.*_outlet"
    {
        type            inletOutlet;
        value           $internalField;
        inletValue      $internalField;
    }

    "rack.*_inlet"
    {
        type            turbulentMixingLengthDissipationRateInlet;
        mixingLength    0.1;
        value           $internalField;
    }
    "rack.*_outlet"
    {
        type            inletOutlet;
        value           $internalField;
        inletValue      $internalField;
    }

}



