FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    
    walls
    {
        type            nutLowReWallFunction;
        Cmu             0.09;
        kappa           0.41;
        E               9.8;
        value           uniform 0();
    }

    hole
    {
        type            calculated;
        value           $internalField;
    }

    "crac.*_inlet"
    {
        type            calculated;
        value           $internalField;
    }
    "crac.*_outlet"
    {
        type            calculated;
        value           $internalField;
    }

    "rack.*_inlet"
    {
        type            calculated;
        value           $internalField;
    }
    "rack.*_outlet"
    {
        type            calculated;
        value           $internalField;
    }

}


