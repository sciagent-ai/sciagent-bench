FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      alphat;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// kinematic turbulent thermal conductivity, goes into turbulent prandtl number

dimensions      [1 -1 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{

    walls
    {
        type            compressible::alphatJayatillekeWallFunction;
        Prt             0.85;
        value           uniform 0;
    }

    hole
    {
        type calculated;
        value uniform 0;
    }

    "crac.*_inlet"
    {
        type calculated;
        value uniform 0;
    }
    "crac.*_outlet"
    {
        type calculated;
        value uniform 0;
    }

    "rack.*_inlet"
    {
        type calculated;
        value uniform 0;
    }
    "rack.*_outlet"
    {
        type calculated;
        value uniform 0;
    }

}


