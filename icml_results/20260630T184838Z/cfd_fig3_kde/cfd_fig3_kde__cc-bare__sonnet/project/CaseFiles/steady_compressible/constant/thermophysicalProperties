FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleEnthalpy;
}

//pRef    101325;
dpdt off; // important

mixture
{
    specie
    {
        molWeight       28.96; // not used in puremixture?
    }
    thermodynamics
    {
        Cp              1006;
        Hf              0;
    }
    transport
    {
        mu              1.82678e-05; // 1.516e-5*1.205 by reference density
        Pr              0.71;
        // Prt in turb model?
    }
}



