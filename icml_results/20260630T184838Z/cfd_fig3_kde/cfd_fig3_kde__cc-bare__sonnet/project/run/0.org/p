FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    walls           { type calculated; value $internalField; }
    hole            { type calculated; value $internalField; }
    "crac.*_inlet"  { type calculated; value $internalField; }
    "crac.*_outlet" { type calculated; value $internalField; }
    "rack.*_inlet"  { type calculated; value $internalField; }
    "rack.*_outlet" { type calculated; value $internalField; }
}

