system("pwd")

#set terminal qt 0
set terminal pngcairo enhanced font "Times New Roman,12.0" size 1500,700
set output 'residuals.png'
set logscale y 10
set format y "%g"
set title "Residuals"
set ylabel 'Residual'
set xlabel 'Iteration'
set grid y

plot "< cat log3_solver | grep 'Solving for Ux' | cut -d' ' -f9 | tr -d ','" title 'Ux' w l,\
"< cat log3_solver | grep 'Solving for Uy' | cut -d' ' -f9 | tr -d ','" title 'Uy' w l,\
"< cat log3_solver | grep 'Solving for Uz' | cut -d' ' -f9 | tr -d ','" title 'Uz' w l,\
"< cat log3_solver | grep 'Solving for T' | cut -d' ' -f9 | tr -d ','" title 'h' w l,\
"< cat log3_solver | grep 'Solving for p_rgh' | cut -d' ' -f9 | tr -d ','" every 4::3 title 'p_{rgh}' w l,\
"< cat log3_solver | grep 'Solving for omega' | cut -d' ' -f9 | tr -d ','" title 'omega' w l,\
"< cat log3_solver | grep 'Solving for epsilon' | cut -d' ' -f9 | tr -d ','" title 'epsilon' w l,\
"< cat log3_solver | grep 'Solving for k' | cut -d' ' -f9 | tr -d ','" title 'k' w l

system("tail -n 50 log3_solver")
system("echo 'redidualplotter idle'")
pause 5
reread