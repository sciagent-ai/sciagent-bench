FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      epsilon;        
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.001;

boundaryField
{

    walls
    {
        type            epsilonWallFunction;
        lowReCorrection on;
        value           $internalField;
    }

    hole
    {
        type            zeroGradient;
    }

    "crac.*_inlet"
    {
        type            turbulentMixingLengthDissipationRateInlet;
        mixingLength    0.1;
        value           uniform 0;
    }
    "crac.*_outlet"
    {
        type            inletOutlet;
        value           $internalField;
        inletValue      uniform 0.001;
    }

    "rack.*_inlet"
    {
        type            turbulentMixingLengthDissipationRateInlet;
        mixingLength    0.1;
        value           uniform 0;
    }
    "rack.*_outlet"
    {
        type            inletOutlet;
        value           $internalField;
        inletValue      uniform 0.001;
    }

}



